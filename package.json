{
  "name": "magictaskbar-ui",
  "version": "2.4.4",
  "type": "module",
  "scripts": {
    "tauri": "tauri",
    "build:ui": "tsx scripts/build.ts",
    "build:lib": "cd ./libs/core && deno task build && cd ../..",
    "dev": "cargo build && tsx scripts/patch-exe.ts && tauri dev",
    "build:release": "npm run build:lib && npm run build:ui -- --production && tauri build && tsx scripts/patch-exe.ts",
    "type-check": "tsc --noEmit",
    "preinstall": "npm run build:lib"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@preact/compat": "^18.3.1",
    "@preact/signals": "^2.3.1",
    "@tauri-apps/api": "2.11.0",
    "@tauri-apps/cli": "2.11.0",
    "@tauri-apps/plugin-dialog": "2.3.3",
    "@tauri-apps/plugin-fs": "2.5.1",
    "@tauri-apps/plugin-log": "2.6.0",
    "@tauri-apps/plugin-process": "2.3.0",
    "preact": "^10.27.1",
    "preact-render-to-string": "^6.6.1",
    "react-icons": "^5.5.0"
  },
  "devDependencies": {
    "@reduxjs/toolkit": "^2.5.0",
    "@magic-ui/lib": "file:libs/core/npm",
    "@types/express": "^5.0.3",
    "@types/js-yaml": "^4.0.9",
    "@types/lodash": "^4.17.7",
    "@types/node": "^20.11.19",
    "@types/react-dom": "^18.2.19",
    "@types/yargs": "^17.0.33",
    "antd": "^5.23.0",
    "esbuild": "^0.25.5",
    "esbuild-css-modules-plugin": "^3.1.4",
    "express": "^4.21.2",
    "framer-motion": "^12.23.0",
    "i18next": "^23.12.2",
    "js-yaml": "^4.1.0",
    "lodash": "^4.17.21",
    "moment": "^2.30.1",
    "react-dom": "^19.2.0",
    "react-i18next": "^15.0.0",
    "react-redux": "^9.1.0",
    "readable-types": "^4.0.0",
    "redux": "^5.0.1",
    "toml": "^3.0.0",
    "tsx": "^4.19.3",
    "typescript": "5.3.3",
    "yargs": "^17.7.2",
    "zod": "^3.24.3"
  }
